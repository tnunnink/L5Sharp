        <Tags>
          <Tag Name="LocalDint" TagType="Base" DataType="DINT" Radix="Decimal" Constant="false" ExternalAccess="Read/Write" OpcUaAccess="None">
            <Data Format="L5K"><![CDATA[15541]]></Data>
            <Data Format="Decorated">
              <DataValue DataType="DINT" Radix="Decimal" Value="15541" />
            </Data>
          </Tag>
